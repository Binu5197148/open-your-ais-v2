---
import { ADSENSE_CLIENT } from '../consts';
interface Props {
  slot: string;
  format?: string;
  responsive?: boolean;
}
const { slot, format = 'auto', responsive = true } = Astro.props;
---

<div class="adsense-slot">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client={ADSENSE_CLIENT}
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive={responsive ? 'true' : 'false'}></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>
