---
import FormattedDate from './FormattedDate.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category?: string;
  readTime?: string;
}
const { href, title, description, pubDate, category, readTime } = Astro.props;
---

<a href={href} class="card" style="display: block; text-decoration: none; color: inherit;">
  <div class="card-meta">
    <FormattedDate date={pubDate} />
    {category && <span style="margin-left: 1em;">· {category}</span>}
    {readTime && <span style="margin-left: 1em;">· {readTime}</span>}
  </div>
  <h2 class="card-title">{title}</h2>
  <p class="card-excerpt">{description}</p>
</a>
