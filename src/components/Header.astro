    <a href="/" style="text-decoration: none; font-weight: 800; letter-spacing: -0.02em; font-size: 1.25rem;">{SITE_TITLE}</a>
    <nav style="display: flex; gap: 1.5rem; font-size: 0.95rem;">
      <a href="/blog/">Articles</a>
