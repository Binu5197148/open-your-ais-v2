---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL } from '../consts';
---

<BaseLayout title="Contact" description="Get in touch with Ulisses Balbino.">
  <section class="container" style="padding: 5rem 1.25rem 3rem;">
    <h1 class="title">Contact</h1>
  </section>

  <section class="prose">
    <p>
      The best way to reach me is through one of the links below. I read everything,
      but I don't always answer fast — I'm usually on a set.
    </p>
    <ul>
      <li><a href="mailto:ulisses@openyourais.com">ulisses@openyourais.com</a></li>
      <li><a href={SOCIAL.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
      <li><a href={SOCIAL.instagram} target="_blank" rel="noopener">Instagram</a></li>
      <li><a href={SOCIAL.x} target="_blank" rel="noopener">X (Twitter)</a></li>
    </ul>
    <p>
      For production inquiries, reach out via
      <a href="https://pichorrafilmes.com.br" target="_blank" rel="noopener">Pichorra Filmes</a>.
    </p>
  </section>
</BaseLayout>
