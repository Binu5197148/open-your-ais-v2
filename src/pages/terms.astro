---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = 'April 20, 2026';
---

<BaseLayout title="Terms of Service" description="Terms of service for Open Your AIs.">
  <header class="container" style="padding-top: calc(var(--s-10) + 60px);">
    <p class="mono" style="color:var(--c-accent)">§ — Legal</p>
    <h1 style="font-family: var(--font-serif); font-size: clamp(48px, 7vw, 112px); letter-spacing: -0.035em; line-height: 0.95; margin-top: var(--s-6); font-weight: 400; max-width: 18ch;">
      Terms of Service
    </h1>
    <p class="mono" style="margin-top: var(--s-5); color: var(--c-fg-muted);">Last updated: {updated}</p>
  </header>

  <section class="container" style="margin-top: var(--s-8);">
    <div class="prose">
      <p class="lead">
        By accessing openyourais.com, you agree to be bound by these terms.
      </p>
      <h2>Content</h2>
      <p>
        The content on this site represents the personal opinions of Ulisses Balbino
        based on his experience as a filmmaker. Product reviews reflect personal tests
        and do not constitute professional advice. AI tools evolve rapidly — specific
        product claims may become outdated.
      </p>
      <h2>Intellectual property</h2>
      <p>
        All original writing, images, and branding on this site are the property of
        Ulisses Balbino unless otherwise noted. Do not reproduce without attribution
        and a link back to the source article.
      </p>
      <h2>External links</h2>
      <p>
        This site links to third-party websites for reference. We're not responsible
        for the content or practices of those sites.
      </p>
      <h2>No warranty</h2>
      <p>
        The content is provided "as is" without warranty of any kind. Your use of the
        site is at your own risk.
      </p>
      <h2>Contact</h2>
      <p>Email <a href="mailto:ulisses@openyourais.com">ulisses@openyourais.com</a>.</p>
    </div>
  </section>
</BaseLayout>
